[importlinter]
root_package = app

[importlinter:contract:layers]
name = Clean Architecture layers (domain < infrastructure < usecase < transport)
type = layers
layers =
    app.transport
    app.usecase
    app.infrastructure
    app.domain

[importlinter:contract:domain-independence]
name = Domain layer must not depend on any other layer
type = forbidden
source_modules =
    app.domain
forbidden_modules =
    app.infrastructure
    app.usecase
    app.transport

[importlinter:contract:usecase-no-transport]
name = Usecase layer must not depend on transport
type = forbidden
source_modules =
    app.usecase
forbidden_modules =
    app.transport

[importlinter:contract:transport-no-direct-db]
name = Transport must not depend on db implementations
type = forbidden
source_modules =
    app.transport
forbidden_modules =
    app.infrastructure.db
ignore_imports =
    app.di -> app.infrastructure.db.player_repository
    app.di -> app.infrastructure.db.room_repository
    app.di -> app.infrastructure.db.game_repository
    app.di -> app.infrastructure.db.game_event_repository
    app.di -> app.infrastructure.db.unit_of_work
    app.di -> app.infrastructure.db.matchmaking_repository
